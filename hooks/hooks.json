{
  "version": 1,
  "description": "Copilot Omni lifecycle hooks — pure Python, stdlib only, corporate-safe",
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py\"",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre_tool_use.py\"",
        "timeout": 8
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use.py\"",
        "timeout": 8
      }
    ],
    "userPromptSubmit": [
      {
        "type": "command",
        "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit.py\"",
        "timeout": 5
      }
    ]
  }
}

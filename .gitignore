# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Runtime state (NOT tracked) — only .omni/config.json and .omni/specs are tracked
.omni/audit/
.omni/autopilot/
.omni/cache/
.omni/deferred/
.omni/plans/
.omni/research/
.omni/runs/
.omni/sessions/
.omni/state/
.omni/workspaces/
# omni-rename-allow: historical-citation
.omc/
.claude/
.sisyphus/
*.db
*.db-journal
*.db-wal
*.db-shm

# IDE and OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Virtual envs (should not be here, but just in case)
.venv/
venv/
env/

# Test artifacts
.coverage
coverage.json
.pytest_cache/
htmlcov/
# Fake-subagent invocation count sidecars (generated by OMNI_SUBAGENT_FAKE_RESPONSE_FILE)
*.counts.json

# Build artifacts (none should exist — we ship no binaries)
*.exe
*.dll
*.so
*.dylib
dist/

# Internal development docs
docs/internal/

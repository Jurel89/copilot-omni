# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Runtime state (NOT tracked) — .omni/plans, .omni/research, .omni/specs ARE tracked
.omni/audit/
.omni/autopilot/
.omni/cache/
.omni/deferred/
.omni/runs/
.omni/sessions/
.omni/state/
.omni/workspaces/
.omc/
.claude/
.sisyphus/
*.db
*.db-journal
*.db-wal
*.db-shm

# IDE and OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Virtual envs (should not be here, but just in case)
.venv/
venv/
env/

# Test artifacts
.coverage
.pytest_cache/
htmlcov/

# Build artifacts (none should exist — we ship no binaries)
*.exe
*.dll
*.so
*.dylib
dist/

# Internal development docs
docs/internal/

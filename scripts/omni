#!/usr/bin/env bash
# POSIX shim — dispatches to whichever Python 3 is on PATH.
# Order: python3 → python. Fails loudly if none found.
set -e

script_dir="$(cd "$(dirname "$0")" && pwd)"
target="$script_dir/omni.py"

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$target" "$@"
fi

if command -v python >/dev/null 2>&1; then
  # Verify it's Python 3 before dispatching.
  if python -c 'import sys; sys.exit(0 if sys.version_info>=(3,9) else 1)' 2>/dev/null; then
    exec python "$target" "$@"
  fi
fi

echo "ERROR: no Python 3.9+ interpreter found on PATH (tried: python3, python)" >&2
echo "       install Python 3.9+ from your package manager or https://www.python.org/downloads/" >&2
exit 127

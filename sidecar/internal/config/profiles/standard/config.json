{
  "version": "1",
  "profile": "standard",
  "policy": {
    "strict_mode": false,
    "protected_paths": ["src/"],
    "denied_commands": ["sudo", "rm -rf /", "mkfs", "dd"],
    "max_autopilot_turns": 15
  },
  "memory": {
    "enabled": true,
    "max_size_mb": 200,
    "retention_days": 90,
    "auto_ingest": true
  },
  "sidecar": {
    "debug": false
  },
  "research": {
    "max_subtasks": 4,
    "parallel_read": true,
    "parallel_write": false
  },
  "enterprise": {
    "offline_mode": false,
    "audit_retention_days": 90,
    "signing_enabled": false
  }
}

{
  "version": "1",
  "profile": "standard",
  "policy": {
    "strict_mode": false,
    "protected_paths": ["src/"],
    "denied_commands": ["sudo", "rm -rf /", "mkfs", "dd"],
    "max_autopilot_turns": 15
  },
  "memory": {
    "enabled": true,
    "max_size_mb": 200
  },
  "sidecar": {
    "debug": false
  }
}

{
  "profile": "strict",
  "description": "Maximum restrictions — block all privileged operations and pipeline-to-shell patterns.",
  "deny_commands": [
    "sudo",
    "su ",
    "rm -rf",
    "rm -r",
    "mkfs",
    "dd if=",
    "dd of=",
    ":(){",
    "curl ",
    "wget ",
    "chmod 777",
    "chmod -R",
    "chown ",
    "kill -9",
    "> /dev/",
    "|sh",
    "| sh",
    "|bash",
    "| bash"
  ],
  "protected_paths": [
    ".omni/",
    ".github/",
    "plugin.json",
    "AGENTS.md",
    ".git/",
    "hooks/",
    "mcp/",
    "scripts/"
  ]
}

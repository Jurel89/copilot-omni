{
  "profile": "standard",
  "description": "Balanced policy — blocks dangerous commands and protects plugin-managed files.",
  "deny_commands": [
    "sudo ",
    "rm -rf /",
    "mkfs",
    "dd if=/dev/zero",
    ":(){ :|:& };:",
    "curl -fsSL",
    "wget -O-"
  ],
  "protected_paths": [
    ".omni/config.json",
    ".github/copilot-instructions.md",
    ".claude-plugin/plugin.json",
    "AGENTS.md"
  ]
}
